{
  "version": 1,
  "hooks": {
    "subagentStop": [
      {
        "command": "python3 ./hooks/domino-subagent-stop.py",
        "timeout": 15,
        "loop_limit": 12
      }
    ],
    "stop": [
      {
        "command": "python3 ./hooks/domino-stop.py",
        "timeout": 15,
        "loop_limit": 12
      }
    ]
  }
}
